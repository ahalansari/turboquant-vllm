# Copy to .env and adjust. Every value here is the default the stack uses.

# --- Image build ---
VLLM_TAG=v0.19.0
TRANSFORMERS_VERSION=5.5.0

# --- Model (settings from the working Gemma 4 deployment) ---
MODEL=lcu0312/gemma-4-26B-A4B-it-AWQ-4bit
QUANTIZATION=awq
MAX_MODEL_LEN=4096
MAX_NUM_SEQS=4
DTYPE=half

# --- Hardware ---
TENSOR_PARALLEL=2
GPU_MEMORY_UTIL=0.85

# --- TurboQuant KV-cache compression ---
TURBOQUANT=true
TQ4_K_BITS=4
TQ4_V_BITS=4

# --- Server ---
HOST_PORT=8000
HF_CACHE_DIR=/mnt/user/appdata/vllm-turboquant/hf-cache
ENABLE_THINKING=false
# Gemma 4 tool calling:
EXTRA_ARGS=--enable-auto-tool-choice --tool-call-parser gemma4
# Only needed for gated models:
HF_TOKEN=
